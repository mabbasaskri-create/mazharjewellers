rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'm.abbas.askri@gmail.com';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Public read, admin write
    match /heroBanner/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /collections/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users - self read/write, admin full access
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
    }

    // Orders - customers read own (by userId), admin full access
    match /orders/{orderId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Analytics - admin only
    match /analytics/{doc} {
      allow read, write: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
